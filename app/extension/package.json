{
  "name": "agent-quest-companion",
  "displayName": "Agent Quest Companion",
  "description": "Live Agent Quest companion panel in VS Code.",
  "version": "0.0.1",
  "publisher": "natpat",
  "license": "MIT",
  "icon": "media/icon.png",
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "claude",
    "claude code",
    "rpg",
    "gamification",
    "ai agent",
    "pixel art",
    "companion"
  ],
  "galleryBanner": {
    "color": "#2a2118",
    "theme": "dark"
  },
  "homepage": "https://github.com/Hin-Nattapat/agent-quest#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hin-Nattapat/agent-quest"
  },
  "bugs": {
    "url": "https://github.com/Hin-Nattapat/agent-quest/issues"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "panel": [
        {
          "id": "agentQuestPanel",
          "title": "Agent Quest",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "agentQuestPanel": [
        {
          "id": "agentQuest.companion",
          "type": "webview",
          "name": "Companion"
        }
      ]
    },
    "commands": [
      {
        "command": "agentQuest.openCompanion",
        "title": "Agent Quest: Open Companion"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "copy-webview": "node scripts/copy-webview.mjs",
    "build:all": "npm --prefix .. run build && npm run copy-webview && npm run build",
    "package": "npm run build:all && vsce package --no-dependencies",
    "reinstall": "npm run package && code --install-extension \"$(ls -t agent-quest-companion-*.vsix | head -1)\" --force",
    "publish": "npm run build:all && vsce publish --no-dependencies",
    "publish:ovsx": "npm run package && ovsx publish \"$(ls -t agent-quest-companion-*.vsix | head -1)\"",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  }
}
